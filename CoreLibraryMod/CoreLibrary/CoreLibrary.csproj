<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    
    <ModName>CoreLibraryMod</ModName>
    <ModType>library</ModType>
    <AutoInstallMod Condition="'$(Configuration)' == 'Debug'">true</AutoInstallMod>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="DeadCellsCoreModding.MDK" Version="1.0.1" />
    <ProjectReference Include="..\JqFormatter\JqFormatter\JqFormatter.csproj" />
    <ProjectReference Include="C:\Users\Michael\core\sources\ModCore.Native\ModCore.Native.csproj"/>
  </ItemGroup>

  <ItemGroup>

    <Reference Include="JqFormatter" />
    <ModDependency Include="JqFormatter" />

    <Reference Include="DebugConsole" />
    <ModDependency Include="DebugConsole" />

    <Reference Include="SinPointer" />
  </ItemGroup>

  <ItemGroup>
    <None Update="NativeLib\SinPointer.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
    <ModName>CoreLibraryMod</ModName>
    <ModType>library</ModType>
    <AutoInstallMod Condition="'$(Configuration)' == 'Debug'">true</AutoInstallMod>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
